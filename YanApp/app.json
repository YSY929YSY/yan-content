{
  "expo": {
    "name": "YanApp",
    "slug": "YanApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ysy929ysy.yan",
      "buildNumber": "1",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "言需要访问照片图库，用于上传世界足迹打卡照片。",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      [
        "expo-image-picker",
        {
          "photosPermission": "言需要访问照片图库，用于上传世界足迹打卡照片。"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "390f09a4-3211-4fec-8702-45ee711a9245"
      }
    }
  }
}
